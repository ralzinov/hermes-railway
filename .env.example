# Required at deploy time (Railway Shared Variables)
OPENROUTER_API_KEY=sk-or-...
COMPOSIO_MCP_KEY=comp_...

# Shared — same value on hermes + supermemory (Railway template default:
# sm_${{secret(48, "0123456789abcdef")}})
SUPERMEMORY_API_KEY=sm_

# Optional — hardcoded default on Railway: http://supermemory.railway.internal:6767
# docker-compose sets http://supermemory:6767 automatically
# SUPERMEMORY_BASE_URL=

# Optional (Hermes) — auto-generated and logged on first boot if unset
# API_SERVER_KEY=
